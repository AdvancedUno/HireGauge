# --- Required for the default Claude provider ---
ANTHROPIC_API_KEY=

# --- Optional: raises GitHub API rate limit from 60 to 5000 requests/hour ---
GITHUB_TOKEN=

# --- Optional alternative providers ---
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_HOST=http://localhost:11434

# --- Optional: Kaggle collector (https://www.kaggle.com/settings -> API) ---
KAGGLE_USERNAME=
KAGGLE_KEY=

# --- Defaults (override the CLI defaults) ---
DEFAULT_PROVIDER=anthropic
DEFAULT_MODEL=claude-opus-4-8
CACHE_ENABLED=true
CACHE_DIR=.hireme_cache
